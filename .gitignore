# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code のローカル設定（マシン固有・権限固有）
.claude/

# タスク指示書（使い捨て・コミット禁止）
task_*.md
/指示書_*.md
/引き継ぎメモ*.md
/airistoppc_1440x540.jpg

# 個人メモ・下書き（マシン固有・コミット禁止）
/コラムドラフト/
/*まとめ_*.md

# FUSE マウントの一時残骸（編集時に発生・コミット禁止）
.fuse_hidden*

# 古い版のバックアップ退避（コミット不要）
/_stale_backup*/

# 削除待ち退避（この環境ではrm不可のため一時退避・ユーザーが後で削除）
/_to_delete*/
